<Window x:Class="ANVESHA_TCRX_HEALTH_STATUS_GUI_V2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ANVESHA_TCRX_HEALTH_STATUS_GUI_V2.Converters"
        Title="ANVESHA — TCRX Health Status Monitor V2"
        Height="960" Width="1520"
        MinHeight="800" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DarkBgBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowState="Maximized"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BoolToConnectionTextConverter x:Key="ConnTextConv"/>
        <conv:BoolToStatusBrushConverter    x:Key="ConnBrushConv"/>
        <conv:BoolToButtonTextConverter     x:Key="BtnTextConv"/>
        <conv:InverseBoolConverter          x:Key="InvBoolConv"/>
        <conv:BoolToVisibilityConverter     x:Key="BoolToVisConv"/>


  
        
        <!-- ═══════════════════════════════════════════════════════════
             TAB CONTROL STYLE
        ════════════════════════════════════════════════════════════════ -->
        <Style x:Key="DarkTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource DarkBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBgBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             TAB ITEM STYLE
        ════════════════════════════════════════════════════════════════ -->
        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="6,6,0,0"
                                Margin="2,0,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{StaticResource MidBgBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{StaticResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <!-- R0 Title bar       -->
            <RowDefinition Height="32"/>
            <!-- R1 Protocol strip  -->
            <RowDefinition Height="Auto"/>
            <!-- R2 Control panel   -->
            <RowDefinition Height="*"/>
            <!-- R3 TAB CONTROL     -->
            <RowDefinition Height="28"/>
            <!-- R4 Status bar      -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             R0  TITLE BAR
        ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource MidBgBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Rectangle Grid.Column="0" Fill="{StaticResource AccentBrush}"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0">
                    <TextBlock Text="ANVESHA  —  TCRX  HEALTH  STATUS  MONITOR"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Dual RS422 Serial Port  |  Frame Acquisition &amp; Analysis System  |  V2.0"
                               FontSize="11"
                               Foreground="{StaticResource SubTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Background="#FF0D1526"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Margin="10,10" Padding="18,4">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="SESSION UPTIME" FontSize="8"
                                   Foreground="{StaticResource SubTextBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding UptimeText}"
                                   FontSize="22" FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource GreenBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             R1  PROTOCOL STRIP
        ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#FF070C18"
                BorderBrush="{StaticResource PanelBgBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <TextBlock Text="PROTOCOL:" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource YellowBrush}" Margin="0,0,10,0"/>
                <TextBlock Text="SIZE=26B" FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="|" Foreground="{StaticResource SubTextBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="HDR[0]=0x0D  HDR[1]=0x0A" FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="|" Foreground="{StaticResource SubTextBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="FOOTER[25]=0xAB" FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="|" Foreground="{StaticResource SubTextBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="EXTRACT[16..23]=8B" FontFamily="Consolas" FontSize="10"
                           FontWeight="Bold" Foreground="{StaticResource GreenBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="|" Foreground="{StaticResource SubTextBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="RS422 @ 230400 BAUD" FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource YellowBrush}"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             R2  CONTROL PANEL
        ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="6,4,6,0"
        Background="{StaticResource MidBgBrush}"
        BorderBrush="{StaticResource AccentBrush}"
        BorderThickness="1" CornerRadius="4"
        Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Section label -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="DUAL PORT CONFIGURATION  &amp;  CONTROL"
                       FontSize="12" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"/>

                    <Border Background="#FF0D1526"
                    BorderBrush="{StaticResource PanelBgBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Padding="10,2" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{Binding IsAcquiring, Converter={StaticResource ConnBrushConv}}"/>
                            <TextBlock Text="{Binding AcquisitionStatus}"
                               FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="{Binding IsAcquiring, Converter={StaticResource ConnBrushConv}}"
                               VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Controls row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="2"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- PORT 1 -->
                    <TextBlock Grid.Column="0" Text="PORT 1:" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource GreenBrush}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}"
                      ItemsSource="{Binding Port1.AvailablePorts}"
                      SelectedItem="{Binding Port1.SelectedPort}"
                      IsEnabled="{Binding IsAcquiring, Converter={StaticResource InvBoolConv}}"/>
                    <TextBlock Grid.Column="3" Text="Baud:" FontSize="10"
                       Foreground="{StaticResource SubTextBrush}"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Grid.Column="4" Style="{StaticResource DarkComboBox}"
                      ItemsSource="{Binding Port1.BaudRates}"
                      SelectedItem="{Binding Port1.SelectedBaudRate}"
                      IsEnabled="{Binding IsAcquiring, Converter={StaticResource InvBoolConv}}"/>

                    <!-- Divider -->
                    <Rectangle Grid.Column="6" Width="2"
                       Fill="{StaticResource PanelBgBrush}" Margin="0,2"/>

                    <!-- PORT 2 -->
                    <TextBlock Grid.Column="8" Text="PORT 2:" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource YellowBrush}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="9" Style="{StaticResource DarkComboBox}"
                      ItemsSource="{Binding Port2.AvailablePorts}"
                      SelectedItem="{Binding Port2.SelectedPort}"
                      IsEnabled="{Binding IsAcquiring, Converter={StaticResource InvBoolConv}}"/>
                    <TextBlock Grid.Column="11" Text="Baud:" FontSize="10"
                       Foreground="{StaticResource SubTextBrush}"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Grid.Column="12" Style="{StaticResource DarkComboBox}"
                      ItemsSource="{Binding Port2.BaudRates}"
                      SelectedItem="{Binding Port2.SelectedBaudRate}"
                      IsEnabled="{Binding IsAcquiring, Converter={StaticResource InvBoolConv}}"/>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="14" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="⟳  REFRESH" Style="{StaticResource ProfessionalButton}"
                        Width="100" Margin="0,0,8,0"
                        IsEnabled="{Binding IsAcquiring, Converter={StaticResource InvBoolConv}}"
                        Click="BtnRefresh_Click" ToolTip="Rescan COM ports"/>

                        <Button Content="▶  CONNECT BOTH" Style="{StaticResource ConnectButton}"
                        Width="140" FontSize="12" FontWeight="Bold" Margin="0,0,8,0"
                        IsEnabled="{Binding IsAcquiring, Converter={StaticResource InvBoolConv}}"
                        Click="BtnConnect_Click" ToolTip="Connect both ports"/>

                        <Button Content="■  DISCONNECT BOTH" Style="{StaticResource DisconnectButton}"
                        Width="160" FontSize="12" FontWeight="Bold" Margin="0,0,8,0"
                        IsEnabled="{Binding IsAcquiring}"
                        Click="BtnDisconnect_Click" ToolTip="Disconnect both ports"/>

                        <!-- NEW BUTTONS -->
                        <Button Content="▶  START ALL" Style="{StaticResource ConnectButton}"
                        Width="130" FontSize="12" FontWeight="Bold" Margin="0,0,8,0"
                        IsEnabled="{Binding IsAcquiring, Converter={StaticResource InvBoolConv}}"
                        Click="BtnStartAll_Click" ToolTip="Connect ports and start acquisition"/>

                        <Button Content="■  STOP ALL" Style="{StaticResource DisconnectButton}"
                        Width="120" FontSize="12" FontWeight="Bold" Margin="0,0,8,0"
                        IsEnabled="{Binding IsAcquiring}"
                        Click="BtnStopAll_Click" ToolTip="Stop acquisition and disconnect"/>

                        <Button Content="✕  CLEAR LOGS" Style="{StaticResource ProfessionalButton}"
                        Width="120" Click="BtnClearAll_Click" ToolTip="Clear all logs"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             R3  TAB CONTROL (6 TABS)
        ════════════════════════════════════════════════════════════════ -->
        <TabControl Grid.Row="3"
                    Margin="6,6,6,4"
                    Style="{StaticResource DarkTabControl}">

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 1: 26 BYTES RAW FRAMES
            ════════════════════════════════════════════════════════════ -->
            <TabItem Header="📦 26 BYTES RAW FRAMES" Style="{StaticResource DarkTabItem}">
                <Grid Background="{StaticResource MidBgBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PORT 1 RAW -->
                    <Border Grid.Column="0" Background="{StaticResource MidBgBrush}"
                            BorderBrush="{StaticResource GreenBrush}"
                            BorderThickness="2" CornerRadius="4" Margin="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                                    CornerRadius="2,2,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                    <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding Port1.PortStatusColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="PORT 1 — RAW FRAMES  [26 BYTES]" FontSize="13"
                                               FontWeight="Bold" Foreground="{StaticResource GreenBrush}"/>
                                    <TextBlock Text="  [" FontSize="12"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.SelectedPort}" FontSize="12"
                                               FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="{StaticResource YellowBrush}"/>
                                    <TextBlock Text="]" FontSize="12"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Stats -->
                            <Border Grid.Row="1" Background="#FF070C18" Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="TOTAL:" FontSize="10"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.TotalFrames}" FontSize="10"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource TextBrush}" MinWidth="55" Margin="3,0,10,0"/>
                                    <TextBlock Text="VALID:" FontSize="10"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.ValidFrames}" FontSize="10"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource GreenBrush}" MinWidth="55" Margin="3,0,10,0"/>
                                    <TextBlock Text="INVALID:" FontSize="10"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.InvalidFrames}" FontSize="10"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource AccentBrush}" MinWidth="55" Margin="3,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Log -->
                            <TextBox Grid.Row="2" Name="TbPort1Raw"
                                     Style="{StaticResource LogTextBox}"
                                     Text="{Binding Port1.RawLog, Mode=OneWay}"
                                     TextChanged="TbPort1Raw_TextChanged"
                                     Margin="4"/>

                            <!-- File path -->
                            <Border Grid.Row="3" Background="#FF070C18" Padding="8,6">
                                <TextBlock FontSize="9" FontFamily="Consolas"
                                           Foreground="{StaticResource SubTextBrush}">
                                    <Run Text="LOG: "/>
                                   <Run Text="{Binding Port1.RawLogFilePath, Mode=OneWay}"
     Foreground="{StaticResource YellowBrush}"/>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="6"
                                  Background="{StaticResource DarkBgBrush}"
                                  HorizontalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"/>

                    <!-- PORT 2 RAW -->
                    <Border Grid.Column="2" Background="{StaticResource MidBgBrush}"
                            BorderBrush="{StaticResource YellowBrush}"
                            BorderThickness="2" CornerRadius="4" Margin="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                                    CornerRadius="2,2,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                    <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding Port2.PortStatusColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="PORT 2 — RAW FRAMES  [26 BYTES]" FontSize="13"
                                               FontWeight="Bold" Foreground="{StaticResource YellowBrush}"/>
                                    <TextBlock Text="  [" FontSize="12"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.SelectedPort}" FontSize="12"
                                               FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="{StaticResource GreenBrush}"/>
                                    <TextBlock Text="]" FontSize="12"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Stats -->
                            <Border Grid.Row="1" Background="#FF070C18" Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="TOTAL:" FontSize="10"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.TotalFrames}" FontSize="10"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource TextBrush}" MinWidth="55" Margin="3,0,10,0"/>
                                    <TextBlock Text="VALID:" FontSize="10"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.ValidFrames}" FontSize="10"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource GreenBrush}" MinWidth="55" Margin="3,0,10,0"/>
                                    <TextBlock Text="INVALID:" FontSize="10"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.InvalidFrames}" FontSize="10"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource AccentBrush}" MinWidth="55" Margin="3,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Log -->
                            <TextBox Grid.Row="2" Name="TbPort2Raw"
                                     Style="{StaticResource LogTextBox}"
                                     Text="{Binding Port2.RawLog, Mode=OneWay}"
                                     TextChanged="TbPort2Raw_TextChanged"
                                     Margin="4"/>

                            <!-- File path -->
                            <Border Grid.Row="3" Background="#FF070C18" Padding="8,6">
                                <TextBlock FontSize="9" FontFamily="Consolas"
                                           Foreground="{StaticResource SubTextBrush}">
                                    <Run Text="LOG: "/>
                                   <Run Text="{Binding Port2.RawLogFilePath, Mode=OneWay}"
     Foreground="{StaticResource YellowBrush}"/>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 2: 8 BYTES PAYLOAD
            ════════════════════════════════════════════════════════════ -->
            <TabItem Header="📄 8 BYTES PAYLOAD" Style="{StaticResource DarkTabItem}">
                <Grid Background="{StaticResource MidBgBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PORT 1 PAYLOAD -->
                    <Border Grid.Column="0" Background="{StaticResource MidBgBrush}"
                            BorderBrush="{StaticResource GreenBrush}"
                            BorderThickness="2" CornerRadius="4" Margin="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                                    CornerRadius="2,2,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                    <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding Port1.PortStatusColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="PORT 1 — PAYLOAD  [BYTES 16-23]" FontSize="13"
                                               FontWeight="Bold" Foreground="{StaticResource GreenBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="#FF070C18" Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="VALID FRAMES:" FontSize="10"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.ValidFrames}" FontSize="10"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource GreenBrush}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBox Grid.Row="2" Name="TbPort1Payload"
                                     Style="{StaticResource LogTextBox}"
                                     Text="{Binding Port1.PayloadLog, Mode=OneWay}"
                                     TextChanged="TbPort1Payload_TextChanged"
                                     Margin="4"/>

                            <Border Grid.Row="3" Background="#FF070C18" Padding="8,6">
                                <TextBlock FontSize="9" FontFamily="Consolas"
                                           Foreground="{StaticResource SubTextBrush}">
                                    <Run Text="LOG: "/>
                                  <Run Text="{Binding Port1.PayloadLogFilePath, Mode=OneWay}"
     Foreground="{StaticResource GreenBrush}"/>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="6"
                                  Background="{StaticResource DarkBgBrush}"
                                  HorizontalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"/>

                    <!-- PORT 2 PAYLOAD -->
                    <Border Grid.Column="2" Background="{StaticResource MidBgBrush}"
                            BorderBrush="{StaticResource YellowBrush}"
                            BorderThickness="2" CornerRadius="4" Margin="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                                    CornerRadius="2,2,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                    <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding Port2.PortStatusColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="PORT 2 — PAYLOAD  [BYTES 16-23]" FontSize="13"
                                               FontWeight="Bold" Foreground="{StaticResource YellowBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="#FF070C18" Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="VALID FRAMES:" FontSize="10"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.ValidFrames}" FontSize="10"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource GreenBrush}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBox Grid.Row="2" Name="TbPort2Payload"
                                     Style="{StaticResource LogTextBox}"
                                     Text="{Binding Port2.PayloadLog, Mode=OneWay}"
                                     TextChanged="TbPort2Payload_TextChanged"
                                     Margin="4"/>

                            <Border Grid.Row="3" Background="#FF070C18" Padding="8,6">
                                <TextBlock FontSize="9" FontFamily="Consolas"
                                           Foreground="{StaticResource SubTextBrush}">
                                    <Run Text="LOG: "/>
                                    <Run Text="{Binding Port2.PayloadLogFilePath,Mode=OneWay}"
                                         Foreground="{StaticResource GreenBrush}"/>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 3: RX LIVE COMPARE
            ════════════════════════════════════════════════════════════ -->
            <TabItem Header="⚖ RX LIVE COMPARE" Style="{StaticResource DarkTabItem}">
                <Border Background="{StaticResource MidBgBrush}"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="1" CornerRadius="4" Margin="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                                CornerRadius="4,4,0,0" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="REAL-TIME PORT COMPARISON" FontSize="14"
                                           FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Compare incoming data frames from PORT 1 and PORT 2 side-by-side"
                                           FontSize="11" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Comparison view -->
                        <Grid Grid.Row="1" Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- PORT 1 latest frame -->
                            <Border Grid.Column="0" Background="#FF0D1526"
                                    BorderBrush="{StaticResource GreenBrush}"
                                    BorderThickness="2" CornerRadius="4" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="PORT 1 — LATEST FRAME" FontSize="12"
                                               FontWeight="Bold" Foreground="{StaticResource GreenBrush}"
                                               Margin="0,0,0,10"/>
                                    <TextBlock Text="[Live data will appear here when connected]"
                                               FontSize="11" FontFamily="Consolas"
                                               Foreground="{StaticResource SubTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Compare indicator -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="⇄" FontSize="40"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="COMPARE" FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource SubTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- PORT 2 latest frame -->
                            <Border Grid.Column="2" Background="#FF0D1526"
                                    BorderBrush="{StaticResource YellowBrush}"
                                    BorderThickness="2" CornerRadius="4" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="PORT 2 — LATEST FRAME" FontSize="12"
                                               FontWeight="Bold" Foreground="{StaticResource YellowBrush}"
                                               Margin="0,0,0,10"/>
                                    <TextBlock Text="[Live data will appear here when connected]"
                                               FontSize="11" FontFamily="Consolas"
                                               Foreground="{StaticResource SubTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
     TAB 4: RX LIVE STATS
     Displays GenerateDetailedDisplay() output — latest frame only
     No accumulation — no tab switch hang
════════════════════════════════════════════════════════════ -->
            <TabItem Header="RX LIVE STATS" Style="{StaticResource DarkTabItem}">
                <Grid Background="{StaticResource MidBgBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ══════════════════════════════════════════
             PORT 1 — RX LIVE STATS
        ═══════════════════════════════════════════════ -->
                    <Border Grid.Column="0"
                Background="{StaticResource MidBgBrush}"
                BorderBrush="{StaticResource GreenBrush}"
                BorderThickness="2"
                CornerRadius="4"
                Margin="4,6,2,6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <!-- Header      -->
                                <RowDefinition Height="28"/>
                                <!-- Stats strip -->
                                <RowDefinition Height="*"/>
                                <!-- Detail text -->
                                <RowDefinition Height="36"/>
                                <!-- File path   -->
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0"
                        Background="{StaticResource PanelBgBrush}"
                        CornerRadius="2,2,0,0">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Column="0"
                                 Width="12" Height="12"
                                 Margin="0,0,8,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding Port1.PortStatusColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <TextBlock Grid.Column="1"
                                   Text="PORT 1  —  RX LIVE HEALTH STATUS"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GreenBrush}"
                                   VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                   Text="[" FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                   Text="{Binding Port1.SelectedPort}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource YellowBrush}"
                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4"
                                   Text="]"
                                   FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Stats strip -->
                            <Border Grid.Row="1"
                        Background="#FF070C18"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="STATUS: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.ConnectionLabel}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{Binding Port1.IsConnected,
                                               Converter={StaticResource ConnBrushConv}}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="TOTAL: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.TotalFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="VALID: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.ValidFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource GreenBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="INVALID: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.InvalidFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="SHOWING: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="LATEST FRAME ONLY"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource YellowBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Detailed display TextBox
                     RxLiveLog = single latest GenerateDetailedDisplay() entry
                     No large string join = no tab switch hang -->
                            <TextBox Grid.Row="2"
                         Name="TbPort1RxLive"
                         Background="#FF080D18"
                         Foreground="{StaticResource GreenBrush}"
                         FontFamily="Consolas"
                         FontSize="11"
                         BorderThickness="0"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         Text="{Binding Port1.RxLiveLog, Mode=OneWay}"
                         TextChanged="TbPort1RxLive_TextChanged"
                         Margin="4"
                         Padding="8,6"/>

                            <!-- File path row -->
                            <Border Grid.Row="3"
                        Background="#FF070C18"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="LOG: "
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.RxLiveLogFilePath,
                                         Mode=OneWay}"
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource GreenBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1"
                      Width="6"
                      Background="{StaticResource DarkBgBrush}"
                      HorizontalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"/>

                    <!-- ══════════════════════════════════════════
             PORT 2 — RX LIVE STATS
        ═══════════════════════════════════════════════ -->
                    <Border Grid.Column="2"
                Background="{StaticResource MidBgBrush}"
                BorderBrush="{StaticResource YellowBrush}"
                BorderThickness="2"
                CornerRadius="4"
                Margin="2,6,4,6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="36"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0"
                        Background="{StaticResource PanelBgBrush}"
                        CornerRadius="2,2,0,0">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Column="0"
                                 Width="12" Height="12"
                                 Margin="0,0,8,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding Port2.PortStatusColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <TextBlock Grid.Column="1"
                                   Text="PORT 2  —  RX LIVE HEALTH STATUS"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource YellowBrush}"
                                   VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                   Text="["
                                   FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                   Text="{Binding Port2.SelectedPort}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GreenBrush}"
                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4"
                                   Text="]"
                                   FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Stats strip -->
                            <Border Grid.Row="1"
                        Background="#FF070C18"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="STATUS: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.ConnectionLabel}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{Binding Port2.IsConnected,
                                               Converter={StaticResource ConnBrushConv}}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="TOTAL: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.TotalFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="VALID: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.ValidFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource GreenBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="INVALID: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.InvalidFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="SHOWING: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="LATEST FRAME ONLY"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource YellowBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Detailed display TextBox -->
                            <TextBox Grid.Row="2"
                         Name="TbPort2RxLive"
                         Background="#FF080D18"
                         Foreground="{StaticResource YellowBrush}"
                         FontFamily="Consolas"
                         FontSize="11"
                         BorderThickness="0"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         Text="{Binding Port2.RxLiveLog, Mode=OneWay}"
                         TextChanged="TbPort2RxLive_TextChanged"
                         Margin="4"
                         Padding="8,6"/>

                            <!-- File path row -->
                            <Border Grid.Row="3"
                        Background="#FF070C18"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="LOG: "
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.RxLiveLogFilePath,
                                         Mode=OneWay}"
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource YellowBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>


            <!-- ======================================== -->
            <!-- TAB 6: ENHANCED OFFLINE COMPARE         -->
            <!-- ======================================== -->
            <TabItem Header="📂 OFFLINE COMPARE"
         Style="{StaticResource DarkTabItem}">
                <Grid Background="#FF0A0A1A" Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="*"/>
                        <!-- File Selection + Results (scrollable) -->
                    </Grid.RowDefinitions>

                    <!-- ============================== -->
                    <!-- Header Section                 -->
                    <!-- ============================== -->
                    <Border Grid.Row="0"
                Background="#FF0F3460"
                CornerRadius="8"
                Padding="15,10"
                Margin="5,5,5,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="⚖ OFFLINE FILE COMPARISON WITH EXPECTED COMMANDS"
                               Foreground="#FF00D4FF"
                               FontSize="14"
                               FontWeight="Bold"/>
                                <TextBlock Text="Compare expected commands against MAIN and REDUNDANT log files"
                               Foreground="#FF95A5A6"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Quick Status -->
                            <Border Grid.Column="1"
                        Background="#FF0A0A1A"
                        BorderBrush="#FF0F3460"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,6"
                        VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="FILE STATUS"
                                   Foreground="#FF95A5A6"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtOfflineFilesStatus"
                                   Text="0 / 3 selected"
                                   Foreground="#FFFF8C00"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ============================== -->
                    <!-- MAIN CONTENT AREA              -->
                    <!-- Split: Left=File Selection     -->
                    <!--        Right=Results           -->
                    <!-- ============================== -->
                    <Grid Grid.Row="1" Margin="5,3,5,5">
                        <Grid.ColumnDefinitions>
                            <!-- File Selection Panel (fixed width, scrollable) -->
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="5"/>
                            <!-- Results Panel (fills remaining) -->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ============================== -->
                        <!-- LEFT: File Selection Panel     -->
                        <!-- ============================== -->
                        <Border Grid.Column="0"
                    Background="#FF0F1923"
                    BorderBrush="#FF0F3460"
                    BorderThickness="1"
                    CornerRadius="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="10">
                                <StackPanel>

                                    <!-- ======================== -->
                                    <!-- Mode Toggle              -->
                                    <!-- ======================== -->
                                    <Border Background="#FF0A0A1A"
                                BorderBrush="#FF0F3460"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="📁 FILE MODE"
                                           Foreground="#FF00D4FF"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8"/>

                                            <!-- Mode Toggle Buttons -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Single File Mode -->
                                                <Button x:Name="btnOfflineModeSingle"
                                            Grid.Column="0"
                                            Content="📄  Single File"
                                            Height="32"
                                            Click="BtnOfflineModeSingle_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                   BasedOn="{StaticResource ProfessionalButton}">
                                                            <Setter Property="Background"  Value="#FF00D4FF"/>
                                                            <Setter Property="Foreground"  Value="#FF0A0A1A"/>
                                                            <Setter Property="BorderBrush" Value="#FF00D4FF"/>
                                                            <Setter Property="FontWeight"  Value="Bold"/>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Multiple File Mode -->
                                                <Button x:Name="btnOfflineModeMultiple"
                                            Grid.Column="2"
                                            Content="📂  Multiple Files"
                                            Height="32"
                                            Click="BtnOfflineModeMultiple_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                   BasedOn="{StaticResource ProfessionalButton}">
                                                            <Setter Property="Background"  Value="#FF0A1628"/>
                                                            <Setter Property="Foreground"  Value="#FF95A5A6"/>
                                                            <Setter Property="BorderBrush" Value="#FF555577"/>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>

                                            <!-- Mode Description -->
                                            <Border Background="#FF0A0A1A"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        Margin="0,6,0,0">
                                                <TextBlock x:Name="txtOfflineModeDesc"
                                               Text="Single combined log file (Main + Redundant)"
                                               Foreground="#FF00D4FF"
                                               FontSize="10"
                                               TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- ======================== -->
                                    <!-- Expected Commands File   -->
                                    <!-- ======================== -->
                                    <Border Background="#FF0A0A1A"
                                BorderBrush="#FF333322"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,8">
                                        <StackPanel>

                                            <!-- Title -->
                                            <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,8">
                                                <Border Background="#FFFF8C00"
                                            CornerRadius="11"
                                            Width="22" Height="22"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0">
                                                    <TextBlock Text="1"
                                                   Foreground="#FF0A0A1A"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="EXPECTED COMMANDS FILE"
                                                   Foreground="#FFFF8C00"
                                                   FontSize="11"
                                                   FontWeight="Bold"/>
                                                    <TextBlock Text=".txt file with 8-byte hex commands"
                                                   Foreground="#FF555577"
                                                   FontSize="9"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- File Path + Browse -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                            Background="#FF0F1923"
                                            BorderBrush="#FFFF8C00"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="6,4">
                                                    <TextBox x:Name="txtOfflineExpectedFile"
                                                 IsReadOnly="True"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#FFFF8C00"
                                                 FontFamily="Consolas"
                                                 FontSize="10"
                                                 TextWrapping="NoWrap"
                                                 VerticalAlignment="Center"
                                                 Text="No file selected"/>
                                                </Border>

                                                <Button x:Name="btnBrowseExpectedFile"
                                            Grid.Column="2"
                                            Content="📂 Browse"
                                            Style="{StaticResource ProfessionalButton}"
                                            Width="80"
                                            Height="30"
                                            Click="BtnBrowseExpectedFile_Click"/>
                                            </Grid>

                                            <!-- File Info -->
                                            <Border x:Name="borderExpectedFileInfo"
                                        Background="#FF0F1923"
                                        BorderBrush="#FF333344"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,5"
                                        Margin="0,5,0,0"
                                        Visibility="Collapsed">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Name"
                                                       Foreground="#FF555577"
                                                       FontSize="9"/>
                                                        <TextBlock x:Name="txtExpectedFileName"
                                                       Foreground="#FFFF8C00"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       FontFamily="Consolas"
                                                       TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Margin="5,0">
                                                        <TextBlock Text="Size"
                                                       Foreground="#FF555577"
                                                       FontSize="9"/>
                                                        <TextBlock x:Name="txtExpectedFileSize"
                                                       Foreground="#FF00D4FF"
                                                       FontSize="9"
                                                       FontWeight="Bold"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Commands"
                                                       Foreground="#FF555577"
                                                       FontSize="9"/>
                                                        <TextBlock x:Name="txtExpectedFileCount"
                                                       Foreground="#FF00FF88"
                                                       FontSize="9"
                                                       FontWeight="Bold"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="3"
                                                Content="✖"
                                                Width="20" Height="20"
                                                FontSize="9"
                                                Padding="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource ProfessionalButton}"
                                                Click="BtnClearExpectedFile_Click"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- ======================== -->
                                    <!-- SINGLE FILE MODE PANEL   -->
                                    <!-- ======================== -->
                                    <Border x:Name="borderSingleFileMode"
                                Background="#FF0A0A1A"
                                BorderBrush="#FF0F3460"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,8"
                                Visibility="Visible">
                                        <StackPanel>

                                            <!-- Title -->
                                            <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,8">
                                                <Border Background="#FF00D4FF"
                                            CornerRadius="11"
                                            Width="22" Height="22"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0">
                                                    <TextBlock Text="2"
                                                   Foreground="#FF0A0A1A"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="COMBINED LOG FILE"
                                                   Foreground="#FF00D4FF"
                                                   FontSize="11"
                                                   FontWeight="Bold"/>
                                                    <TextBlock Text="Single file with MAIN + REDUNDANT data"
                                                   Foreground="#FF555577"
                                                   FontSize="9"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- File Path + Browse -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                            Background="#FF0F1923"
                                            BorderBrush="#FF00D4FF"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="6,4">
                                                    <TextBox x:Name="txtOfflineSingleFile"
                                                 IsReadOnly="True"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#FF00D4FF"
                                                 FontFamily="Consolas"
                                                 FontSize="10"
                                                 VerticalAlignment="Center"
                                                 Text="No file selected"/>
                                                </Border>

                                                <Button x:Name="btnBrowseSingleFile"
                                            Grid.Column="2"
                                            Content="📂 Browse"
                                            Style="{StaticResource ProfessionalButton}"
                                            Width="80"
                                            Height="30"
                                            Click="BtnBrowseSingleFile_Click"/>
                                            </Grid>

                                            <!-- File Info -->
                                            <Border x:Name="borderSingleFileInfo"
