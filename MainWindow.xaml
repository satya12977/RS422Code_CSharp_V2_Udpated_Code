                                                       Foreground="#FF0A0A1A"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="MAIN DATA FILE"
                                                       Foreground="#FF00FF88"
                                                       FontSize="11"
                                                       FontWeight="Bold"/>
