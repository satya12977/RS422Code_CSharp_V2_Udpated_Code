                                                Height="30"
                                                Click="BtnBrowseMainFile_Click"/>
                                                </Grid>

                                                <!-- File Info -->
                                                <Border x:Name="borderMainFileInfo"
                                            Background="#FF0F1923"
                                            BorderBrush="#FF333344"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,5"
                                            Margin="0,5,0,0"
                                            Visibility="Collapsed">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Name"
                                                           Foreground="#FF555577"
                                                           FontSize="9"/>
                                                            <TextBlock x:Name="txtMainFileName"
                                                           Foreground="#FF00FF88"
                                                           FontSize="9"
                                                           FontWeight="Bold"
                                                           FontFamily="Consolas"
                                                           TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Margin="5,0">
                                                            <TextBlock Text="Size"
                                                           Foreground="#FF555577"
                                                           FontSize="9"/>
