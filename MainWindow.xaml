                                                           Foreground="#FF00D4FF"
                                                           FontSize="9"
                                                           FontWeight="Bold"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Lines"
                                                           Foreground="#FF555577"
                                                           FontSize="9"/>
                                                            <TextBlock x:Name="txtMainFileLines"
                                                           Foreground="#FF00FF88"
                                                           FontSize="9"
                                                           FontWeight="Bold"/>
                                                        </StackPanel>

                                                        <Button Grid.Column="3"
                                                    Content="✖"
                                                    Width="20" Height="20"
                                                    FontSize="9"
                                                    Padding="0"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource ProfessionalButton}"
                                                    Click="BtnClearMainFile_Click"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- Redundant Data File -->
                                        <Border Background="#FF0A0A1A"
                                    BorderBrush="#FF0F3460"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,0,0,8">
                                            <StackPanel>

                                                <!-- Title -->
                                                <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                                    <Border Background="#FF00D4FF"
                                                CornerRadius="11"
                                                Width="22" Height="22"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0">
                                                        <TextBlock Text="3"
                                                       Foreground="#FF0A0A1A"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="REDUNDANT DATA FILE"
                                                       Foreground="#FF00D4FF"
                                                       FontSize="11"
                                                       FontWeight="Bold"/>
                                                        <TextBlock Text="REDUNDANT source log file only"
                                                       Foreground="#FF555577"
                                                       FontSize="9"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- File Path + Browse -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="5"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                Background="#FF0F1923"
                                                BorderBrush="#FF00D4FF"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="6,4">
                                                        <TextBox x:Name="txtOfflineRedundantFile"
                                                     IsReadOnly="True"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="#FF00D4FF"
                                                     FontFamily="Consolas"
                                                     FontSize="10"
                                                     VerticalAlignment="Center"
                                                     Text="No file selected"/>
                                                    </Border>

                                                    <Button x:Name="btnBrowseRedundantFile"
                                                Grid.Column="2"
                                                Content="📂 Browse"
                                                Style="{StaticResource ProfessionalButton}"
                                                Width="80"
                                                Height="30"
                                                Click="BtnBrowseRedundantFile_Click"/>
                                                </Grid>

                                                <!-- File Info -->
                                                <Border x:Name="borderRedundantFileInfo"
                                            Background="#FF0F1923"
                                            BorderBrush="#FF333344"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,5"
                                            Margin="0,5,0,0"
                                            Visibility="Collapsed">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Name"
                                                           Foreground="#FF555577"
                                                           FontSize="9"/>
                                                            <TextBlock x:Name="txtRedundantFileName"
                                                           Foreground="#FF00D4FF"
                                                           FontSize="9"
                                                           FontWeight="Bold"
                                                           FontFamily="Consolas"
                                                           TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Margin="5,0">
                                                            <TextBlock Text="Size"
                                                           Foreground="#FF555577"
                                                           FontSize="9"/>
                                                            <TextBlock x:Name="txtRedundantFileSize"
                                                           Foreground="#FF00D4FF"
                                                           FontSize="9"
                                                           FontWeight="Bold"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Lines"
                                                           Foreground="#FF555577"
                                                           FontSize="9"/>
                                                            <TextBlock x:Name="txtRedundantFileLines"
                                                           Foreground="#FF00FF88"
                                                           FontSize="9"
                                                           FontWeight="Bold"/>
                                                        </StackPanel>

                                                        <Button Grid.Column="3"
                                                    Content="✖"
                                                    Width="20" Height="20"
                                                    FontSize="9"
                                                    Padding="0"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource ProfessionalButton}"
                                                    Click="BtnClearRedundantFile_Click"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- ======================== -->
                                    <!-- STATUS ROW               -->
                                    <!-- ======================== -->
                                    <Border Background="#FF0A0A1A"
                                BorderBrush="#FF0F3460"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📊 STATUS: "
                                           Foreground="#FF95A5A6"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                            <TextBlock x:Name="txtOfflineReadyStatus"
                                           Text="Select files first"
                                           Foreground="#FFFF4444"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ======================== -->
                                    <!-- ACTION BUTTONS           -->
                                    <!-- ======================== -->
                                    <Grid Margin="0,0,0,5">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="5"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 1: Compare + Folders -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button x:Name="btnCompareOfflineFiles"
                                        Grid.Column="0"
                                        Content="⚡ START COMPARE"
                                        Style="{StaticResource ConnectButton}"
                                        Height="36"
                                        FontSize="11"
                                        IsEnabled="False"
                                        Click="BtnCompareOfflineFiles_Click"/>

                                            <Button x:Name="btnOpenLogFolders"
                                        Grid.Column="2"
                                        Content="📁 Open Folders"
                                        Style="{StaticResource ProfessionalButton}"
                                        Height="36"
                                        FontSize="11"
                                        Click="BtnOpenLogFolders_Click"/>
                                        </Grid>

                                        <!-- Row 2: Clear + Export -->
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button x:Name="btnClearOfflineResults"
                                        Grid.Column="0"
                                        Content="🗑 Clear Results"
                                        Style="{StaticResource ProfessionalButton}"
                                        Height="32"
                                        FontSize="11"
                                        Click="BtnClearOfflineResults_Click"/>

                                            <Button x:Name="btnExportOfflineReport"
                                        Grid.Column="2"
                                        Content="💾 Export Report"
                                        Style="{StaticResource ProfessionalButton}"
                                        Height="32"
                                        FontSize="11"
                                        Click="BtnExportOfflineReport_Click"/>
                                        </Grid>
                                    </Grid>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#FF0F3460"
                          ResizeDirection="Columns"/>

                        <!-- ============================== -->
                        <!-- RIGHT: Results Panel           -->
                        <!-- ============================== -->
                        <Border Grid.Column="2"
                    Background="#FF050510"
                    BorderBrush="#FF0F3460"
                    BorderThickness="1"
                    CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <!-- Results Header Bar -->
                                    <RowDefinition Height="45"/>
                                    <!-- Results Content -->
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Results Header -->
                                <Border Grid.Row="0"
                            Background="#FF0F3460"
                            CornerRadius="8,8,0,0"
                            Padding="15,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                            <TextBlock Text="◈"
                                           Foreground="#FFFF8C00"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,0,8,0"/>
                                            <TextBlock Text="OFFLINE COMPARISON RESULTS"
                                           Foreground="#FFFF8C00"
                                           FontWeight="Bold"
                                           FontSize="13"/>
                                        </StackPanel>

                                        <!-- Status Indicator -->
                                        <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                            <Ellipse x:Name="ellipseOfflineStatus"
                                         Width="12" Height="12"
                                         Fill="#FFFF4444"
                                         Margin="0,0,6,0"/>
                                            <TextBlock x:Name="txtOfflineMatchStatus"
                                           Text="Ready - Select files to compare"
                                           Foreground="#FFFF8C00"
                                           FontSize="11"
                                           FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Results Content Area -->
                                <Grid Grid.Row="1">

                                    <!-- Results TextBox with ScrollViewer -->
                                    <TextBox x:Name="txtOfflineCompareResults"
                                 Style="{StaticResource LogTextBox}"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#FFFF8C00"
                                 FontFamily="Consolas"
                                 FontSize="10"
                                 Padding="12,8"/>

                                    <!-- Placeholder when empty -->
                                    <StackPanel x:Name="panelOfflinePlaceholder"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                                        <TextBlock Text="📊"
                                       FontSize="48"
                                       Foreground="#FF333344"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                                        <TextBlock Text="No comparison results yet"
                                       Foreground="#FF555566"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                                        <TextBlock Text="Select files and click START COMPARE"
                                       Foreground="#FF444455"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>



            <!-- ═══════════════════════════════════════════════════════════
                 TAB 6: FRAME COUNTER DISPLAY
            ════════════════════════════════════════════════════════════ -->
            <TabItem Header="🔢 FRAME COUNTER" Style="{StaticResource DarkTabItem}">
                <Border Background="{StaticResource MidBgBrush}"
            BorderBrush="{StaticResource PanelBgBrush}"
            BorderThickness="1" CornerRadius="4" Margin="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                    CornerRadius="4,4,0,0" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="FRAME COUNTER &amp; STATISTICS" FontSize="14"
                               FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock x:Name="txtFrameCounterModeDesc" 
                               Text="Real-time frame counting from connected ports"
                               FontSize="11" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Mode selector -->
                        <Border Grid.Row="1" Background="#FF0A1628"
                    BorderBrush="{StaticResource PanelBgBrush}"
                    BorderThickness="0,1" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="MODE:" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource SubTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <Button x:Name="btnFrameCounterOnline" Content="📡 ONLINE (LIVE)"
                            Style="{StaticResource ProfessionalButton}"
                            Width="150" Margin="0,0,8,0"
                            Click="BtnFrameCounterOnline_Click"/>

                                <Button x:Name="btnFrameCounterOffline" Content="📁 OFFLINE (FILE)"
                            Style="{StaticResource ProfessionalButton}"
                            Width="150"
                            Click="BtnFrameCounterOffline_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Content area -->
                        <Grid Grid.Row="2" x:Name="gridFrameCounterContent">

                            <!-- ══════════════════════════════════════════════════════
                     ONLINE MODE PANEL
                     ═════════════════════════════════════════════════════ -->
                            <Grid x:Name="panelFrameCounterOnline" Visibility="Visible">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- PORT 1 counter -->
                                <Border Grid.Column="0" Background="#FF0D1526"
                            BorderBrush="{StaticResource GreenBrush}"
                            BorderThickness="2" CornerRadius="4"
                            Margin="20">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="PORT 1" FontSize="16"
                                       FontWeight="Bold" Foreground="{StaticResource GreenBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                        <TextBlock Text="{Binding Port1.TotalFrames}" FontSize="72"
                                       FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{StaticResource GreenBrush}"
                                       HorizontalAlignment="Center"/>
                                        <TextBlock Text="TOTAL FRAMES" FontSize="14"
                                       Foreground="{StaticResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>

                                        <Separator Margin="40,20" Background="{StaticResource PanelBgBrush}"/>

                                        <Grid Margin="40,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="VALID" FontSize="11"
                                               Foreground="{StaticResource SubTextBrush}"
                                               HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Port1.ValidFrames}" FontSize="28"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource GreenBrush}"
                                               HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="INVALID" FontSize="11"
                                               Foreground="{StaticResource SubTextBrush}"
                                               HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Port1.InvalidFrames}" FontSize="28"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- PORT 2 counter -->
                                <Border Grid.Column="2" Background="#FF0D1526"
                            BorderBrush="{StaticResource YellowBrush}"
                            BorderThickness="2" CornerRadius="4"
                            Margin="20">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="PORT 2" FontSize="16"
                                       FontWeight="Bold" Foreground="{StaticResource YellowBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                        <TextBlock Text="{Binding Port2.TotalFrames}" FontSize="72"
                                       FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{StaticResource YellowBrush}"
                                       HorizontalAlignment="Center"/>
                                        <TextBlock Text="TOTAL FRAMES" FontSize="14"
                                       Foreground="{StaticResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>

                                        <Separator Margin="40,20" Background="{StaticResource PanelBgBrush}"/>

                                        <Grid Margin="40,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="VALID" FontSize="11"
                                               Foreground="{StaticResource SubTextBrush}"
                                               HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Port2.ValidFrames}" FontSize="28"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource GreenBrush}"
                                               HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="INVALID" FontSize="11"
                                               Foreground="{StaticResource SubTextBrush}"
                                               HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Port2.InvalidFrames}" FontSize="28"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- ══════════════════════════════════════════════════════
                     OFFLINE MODE PANEL
                     ═════════════════════════════════════════════════════ -->
                            <Grid x:Name="panelFrameCounterOffline" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- File selection -->
                                <Border Grid.Row="0" Background="#FF0D1526"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="16" Margin="20,20,20,10">
                                    <StackPanel>
                                        <TextBlock Text="SELECT LOG FILE FOR ANALYSIS" FontSize="12"
                                       FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,0,10"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Background="#FF0A0A1A"
                                        BorderBrush="{StaticResource PanelBgBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="10,8">
                                                <TextBlock x:Name="txtFrameCounterFilePath"
                                               Text="No file selected - Click Browse"
                                               FontSize="11" FontFamily="Consolas"
                                               Foreground="{StaticResource SubTextBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                            </Border>

                                            <Button Grid.Column="1" Content="📁 BROWSE"
                                        Style="{StaticResource ProfessionalButton}"
                                        Click="BtnBrowseFrameCounterFile_Click"/>

                                            <Button Grid.Column="3" Content="🔍 ANALYZE"
                                        Style="{StaticResource ConnectButton}"
                                        x:Name="btnAnalyzeFrameFile"
                                        IsEnabled="False"
                                        Click="BtnAnalyzeFrameFile_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Analysis results -->
                                <Border Grid.Row="1" Background="#FF0D1526"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Margin="20,10,20,20">
                                    <Grid>
                                        <!-- Placeholder -->
                                        <StackPanel x:Name="panelFrameCounterPlaceholder"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="📊" FontSize="72" 
                                           Foreground="{StaticResource PanelBgBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                            <TextBlock Text="No file analyzed yet" FontSize="16"
                                           Foreground="{StaticResource SubTextBrush}"
                                           HorizontalAlignment="Center"/>
                                            <TextBlock Text="Select a log file and click ANALYZE"
                                           FontSize="12" Foreground="{StaticResource SubTextBrush}"
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        </StackPanel>

                                        <!-- Results display -->
                                        <ScrollViewer x:Name="scrollFrameCounterResults"
              Visibility="Collapsed"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Auto"
              Margin="10">
                                            <StackPanel Margin="10">

                                                <!-- Single display TextBox - shows everything -->
                                                <TextBox x:Name="txtFrameCounterDisplay"
                 FontSize="11" FontFamily="Consolas"
                 Foreground="{StaticResource SubTextBrush}"
                 Background="Transparent"
                 BorderThickness="0"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"/>

                                                <!-- Action buttons -->
                                                <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="0,15,0,0">
                                                    <Button Content="OPEN LOG FILE"
                    Style="{StaticResource ProfessionalButton}"
                    Width="150" Margin="0,0,10,0"
                    Click="BtnOpenFrameCounterLog_Click"/>
                                                    <Button Content="OPEN LOG FOLDER"
                    Style="{StaticResource ProfessionalButton}"
                    Width="150"
                    Click="BtnOpenFrameCounterLogFolder_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════════════════════
             R4  STATUS BAR
        ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource MidBgBrush}"
                BorderBrush="{StaticResource PanelBgBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding AppStatus}"
                           FontSize="10" FontFamily="Consolas"
                           Foreground="{StaticResource SubTextBrush}"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0">
                    <TextBlock Text="Frame=26B  |  Extract[16-23]=8B  |  RS422@230400  |  "
                               FontSize="10"
                               Foreground="{StaticResource SubTextBrush}"/>
                    <TextBlock Text="ANVESHA TCRX V2.0"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>